@startuml

package "modele" {
    class Score {
        - m_score : int
        + Score()
        + addScore(point: int) : void
        + getScore() : int
        + resetScore() : void
        + checkVictory() : boolean
    }
}

package "modele.Power" {
    abstract class Power {
        ~ m_name : String
        + Power(name: String)
        + getName() : String
        + getShortName() : String
        + onDebut(board: Board, row: int, col: int) : void
        + onEndTurn(attacker: AnimalCard, currentRow: int, currentCol: int, board: Board) : void
        + modifyDamage(attacker: AnimalCard, defender: Card, damage: int) : int
        + onReceiveDamage(attacker: AnimalCard) : void
        + modifyOpponentAttack(damage: int) : int
    }

    class ContactMortel {
        + ContactMortel()
        + getShortName() : String
        + modifyDamage(attacker: AnimalCard, defender: Card, damage: int) : int
    }

    class Coureur {
        + Coureur()
        + onEndTurn(attacker: AnimalCard, currentRow: int, currentCol: int, board: Board) : void
    }

    class Croissance {
        + Croissance()
        + getShortName() : String
        + onDebut(board: Board, row: int, col: int) : void
    }

    class NombreuseVie {
        + NombreuseVie()
        + getShortName() : String
    }

    class PiquesPointues {
        + PiquesPointues()
        + getShortName() : String
        + onReceiveDamage(attacker: AnimalCard) : void
    }

    class Puant {
        + Puant()
        + modifyOpponentAttack(damage: int) : int
    }

    Power <|-- ContactMortel
    Power <|-- Coureur
    Power <|-- Croissance
    Power <|-- NombreuseVie
    Power <|-- PiquesPointues
    Power <|-- Puant
}

package "modele.board" {
    abstract class Card {
        - m_name : String
        - m_healthPoints : int
        - m_maxHealth : int
        + Card(name: String, healthPoints: int)
        + takeDamage(amount: int) : void
        + isDead() : boolean
        + getNom() : String
        + getMaxHealth() : int
        + getHealthPoints() : int
        + {abstract} getCardAscii() : String[]
        + isAnimal() : Optional<AnimalCard>
        + reHeal() : void
    }

    class AnimalCard {
        - m_attackPoints : int
        - m_bloodCost : int
        - m_boneCost : int
        - isFlying : Boolean
        - m_power : List<Power>
        + AnimalCard(name: String, hp: int, att: int, blo: int, bone: int, fly: boolean)
        + AnimalCard(name: String, hp: int, att: int, blo: int, bone: int, fly: boolean, power: Power)
        + getAttackPoints() : int
        + getBloodCost() : int
        + isFlying() : boolean
        + getBoneCost() : int
        + toString() : String
        + getCardAscii() : String[]
        + isAnimal() : Optional<AnimalCard>
        + getPower() : List<Power>
        + hasPower(powerName: String) : boolean
        + addPower(power: Power) : void
        + setAttack(att: int) : void
    }

    class ObstacleCard {
        + ObstacleCard(name: String, hp: int)
        + getCardAscii() : String[]
        + toString() : String
    }

    class Slot {
        - m_currentCard : Card
        + Slot()
        + isEmpty() : boolean
        + getCard() : Card
        + setCard(c: Card) : void
        + removeCard() : void
        + removeCard(graves: Graves) : void
        + getASCII() : String[]
    }

    class Board {
        + {static} ROW_OPPONENT_QUEUE : int = 0
        + {static} ROW_OPPONENT_ACTIVE : int = 1
        + {static} ROW_PLAYER : int = 2
        - m_grid : Slot[][]
        + Board()
        + addCard(c: Card, row: int, col: int) : boolean
        + getSlot(row: int, col: int) : Slot
        + advanceRow() : void
        + clearBoard(deck: Deck) : void
        - clearPlayerRow(deck: Deck) : void
        - clearAiRow() : void
        + isEmpty(row: int, col: int) : boolean
        + getCard(row: int, col: int) : Card
        + getAnimalCard(row: int, col: int) : Optional<AnimalCard>
        + removeCard(row: int, col: int) : void
        + removeCard(row: int, col: int, graves: Graves) : void
        + setCard(c: Card, row: int, col: int) : void
        + getSlotASCII(row: int, col: int) : String[]
    }

    class CardFactory {
        + CardFactory()
        + {static} createAnimalCard(name: String) : Optional<AnimalCard>
        - {static} addMultipleCard(nom: String, amount: int, deck: Deck) : void
        - {static} getRandomAnimalName() : String
        + {static} initializeDeck(deck: Deck) : void
        + {static} createCardChoice() : AnimalCard[]
        + {static} createRandomObstacle() : ObstacleCard
    }

    Card <|-- AnimalCard
    Card <|-- ObstacleCard
    Slot o--> Card : m_currentCard
    Board *--> Slot : m_grid
}

package "modele.player" {
    abstract class ContainerCard {
        # m_cards : List<AnimalCard>
        + ContainerCard()
        + addCard(card: AnimalCard) : void
        + getCardCount() : int
        + isEmpty() : boolean
        + clear() : void
        + refillDeck(deck: Deck) : void
    }

    class Hand {
        + Hand()
        + getMaxIndex() : int
        + removeCard(index: int) : void
        + getListAsString() : String
        + getCard(index: int) : AnimalCard
    }

    class Deck {
        + Deck()
        + getTopCard() : Optional<AnimalCard>
        + shuffle() : void
        + getList() : List<AnimalCard>
        + sizeDeck() : int
        + getCard(index: int) : AnimalCard
        + deleteCard(index: int) : void
    }

    class Graves {
        - m_bones : int
        + Graves()
        + addCard(card: AnimalCard) : void
        + spendBones(amount: int) : void
        + getBones() : int
        + clear() : void
    }

    abstract class Player {
        - m_hand : Hand
        - m_deck : Deck
        - m_graves : Graves
        + Player()
        + Draw() : void
        + getBones() : int
        + getHandAsString() : String
        + getHand() : Hand
        + draw() : void
        + getGraves() : Graves
        + spendBones(amount: int) : void
        + getDeck() : Deck
        + refillHandToDeck() : void
        + refillGravesToDeck() : void
        + clearGraves() : void
        + shuffleDeck() : void
        + addCardToDeck(card: AnimalCard) : void
        + getDeckSize() : int
        + getDeckCard(index: int) : AnimalCard
        + deleteDeckCard(index: int) : void
        + getHandMaxIndex() : int
        + getHandCard(index: int) : AnimalCard
        + removeHandCard(index: int) : void
        + getHandCardCount() : int
    }

    class HumanPlayer {
        + HumanPlayer()
    }

    class OpponentAI {
        - queue : List<Card>
        + OpponentAI(queue: List<Card>)
        + getIntendedPlays() : List<Card>
        + playTurn(board: Board) : void
    }

    ContainerCard <|-- Hand
    ContainerCard <|-- Deck
    ContainerCard <|-- Graves
    Player *--> Hand : m_hand
    Player *--> Deck : m_deck
    Player *--> Graves : m_graves
    ContainerCard o--> AnimalCard : contient
    Player <|-- HumanPlayer
}

package "vue" {
    enum UserChoice {
        PASSER
        PLACER
    }

    class GameView {
        + GameView()
        - displayLine(b: Board, ligne: int, sc: Score) : void
        + displayBoard(b: Board, sc: Score) : void
        + displayHand(p: Player) : void
        + getSCore(sc: Score) : String[]
        + displayDeck(deck: Deck) : void
        + Clear() : void
        + displayDeckList(deck: Deck) : void
        + displayCardChoices(choices: AnimalCard[]) : void
    }

    class InputHandeler {
        - m_choice : UserChoice
        - m_indexCard : int
        - m_indexSlot : int
        - scanner : Scanner
        - m_stoneChoice : int
        - m_cardChoice : int
        + InputHandeler()
        + getChoice() : UserChoice
        - setChoice(m_choice: UserChoice) : void
        + getIndexCard() : int
        - setIndexCard(m_indexCard: int) : void
        + getIndexSlot() : int
        - setIndexSlot(m_indexSlot: int) : void
        - setStoneChoice(m_stoneChoice: int) : void
        + getStoneChoice() : int
        - setCardChoice(m_cardChoice: int) : void
        + getCardChoice() : int
        + askChoice(maxCardIndex: int) : void
        - getIndexSlot(slot: String) : int
        - getCardIndex(card: String[], maxCardIndex: int) : int
        - parseSlotIndex(slot: String) : int
        + askSacrifices(bloodRequired: int, board: Board) : Optional<List<Integer>>
        + askStoneChoice(indexMax: int, message: String) : void
        + askCardChoice(indexMax: int) : void
    }

    InputHandeler --> UserChoice : m_choice
}

package "Engine" {
    class GameEngine {
        - m_player : HumanPlayer
        - m_opponentAI : OpponentAI
        - m_board : Board
        - m_score : Score
        - m_gameView : GameView
        - m_input : InputHandeler
        + GameEngine(m_player: HumanPlayer, m_score: Score, m_gameView: GameView, m_input: InputHandeler)
        ~ setBoard(board: Board) : void
        ~ getBoard() : Board
        - attackPhase(indexAttackRow: int, indexDefenseRow: int, isPlayerAttack: boolean) : void
        - resolveSlotCombat(indexAttackRow: int, indexDefenseRow: int, isPlayerAttack: boolean, col: int) : void
        - applyDirectDamage(attacker: AnimalCard, damage: int, isPlayerAttack: boolean) : void
        - applyCardDamage(attacker: AnimalCard, defRow: int, defCol: int, damage: int, isPlayerAttack: boolean) : void
        - removeDeadCard(row: int, col: int, isPlayerAttack: boolean) : void
        + play() : void
        ~ chooseNewCard() : void
        ~ Stone() : void
        ~ round() : void
        - applyStartOfTurnEffects(row: int) : void
        ~ playerTurn() : void
        - placeCard(card: AnimalCard, row: int, col: int) : void
        - placeCradBones(card: AnimalCard, row: int, col: int) : void
        ~ initBoard() : void
    }
}

class Main {
    + {static} main(args: String[]) : void
}

Engine.GameEngine *--> modele.player.HumanPlayer : m_player
Engine.GameEngine *--> modele.player.OpponentAI : m_opponentAI
Engine.GameEngine *--> modele.board.Board : m_board
Engine.GameEngine *--> modele.Score : m_score
Engine.GameEngine *--> vue.GameView : m_gameView
Engine.GameEngine *--> vue.InputHandeler : m_input
modele.board.AnimalCard o--> "*" modele.Power.Power : m_power

@enduml
